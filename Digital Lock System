#include <MCUFRIEND_kbv.h>
#include <TouchScreen.h>
#include <EEPROM.h>
#include <Adafruit_Fingerprint.h>
#include <SoftwareSerial.h>

MCUFRIEND_kbv tft;

// ===== TOUCH PINS =====
#define YP A3
#define XM A2
#define YM 9
#define XP 8
#define MINPRESSURE 200
#define MAXPRESSURE 1000
TouchScreen ts = TouchScreen(XP, YP, XM, YM, 300);

// ===== HARDWARE PINS (free from TFT) =====
#define RED_LED   12
#define GREEN_LED 13
#define BUZZER    A5

// ===== FINGERPRINT SCANNER PINS =====
#define FINGER_RX 10   // Arduino RX ← sensor TX (green)
#define FINGER_TX 11   // Arduino TX → sensor RX (white)
SoftwareSerial mySerial(FINGER_RX, FINGER_TX);
Adafruit_Fingerprint finger = Adafruit_Fingerprint(&mySerial);

// ===== SYSTEM VARIABLES =====
String passwords[3] = {"1234", "123", "QWERTY"};
String input = "";
int wrongAttempts = 0;

// TOUCH VARIABLES
bool wasTouching = false;
unsigned long lastTouchTime = 0;

// STATE: 0 = LOCKED, 1 = UNLOCKED, 2 = CHANGING CODE
int systemState = 0;
// MODE: 0 = PIN, 1 = PATTERN, 2 = QWERTY, 3 = FINGERPRINT
int currentMode = 0;

// ===== SETUP =====
void setup() {
  delay(500);

  pinMode(RED_LED, OUTPUT);
  pinMode(GREEN_LED, OUTPUT);
  pinMode(BUZZER, OUTPUT);

  // Start locked
  digitalWrite(RED_LED, HIGH);
  digitalWrite(GREEN_LED, LOW);
  digitalWrite(BUZZER, LOW);

  tft.begin(0x9486);
  tft.setRotation(1);

  loadAllPasswords();

  // Fingerprint sensor init
  finger.begin(57600);        // try 19200 if this fails
  delay(100);
  if (!finger.verifyPassword()) {
    tft.fillScreen(0xF800);
    tft.setTextColor(0xFFFF);
    tft.setTextSize(3);
    tft.setCursor(20, 100);
    tft.print("CHECK SENSOR");
    tft.setCursor(20, 140);
    tft.print("WIRING!");
    while (1) { delay(1); }
  }

  drawScreen();
}

// ===== MAIN LOOP =====
void loop() {
  digitalWrite(YP, HIGH);
  digitalWrite(XM, HIGH);
  TSPoint p = ts.getPoint();
  pinMode(XM, OUTPUT);
  pinMode(YP, OUTPUT);

  // 1. TOUCH SCREEN LOGIC
  if (p.z > MINPRESSURE && p.z < MAXPRESSURE) {
    lastTouchTime = millis();
    wasTouching = true;

    int x = map(p.y, 920, 110, 0, 320);
    int y = map(p.x, 120, 900, 0, 240);

    handleTouch(x, y);

    bool isSwiping = (systemState != 1 && currentMode == 1);
    if (!isSwiping) {
      while (ts.getPoint().z > MINPRESSURE);
      delay(120);
    }
  } else {
    if (wasTouching && (millis() - lastTouchTime > 250)) {
      wasTouching = false;
      if ((systemState == 0 || systemState == 2) && currentMode == 1 && input.length() > 0) {
        processSubmit();
      }
    }
  }

  // 2. FINGERPRINT LOGIC
  if (systemState == 0 && currentMode == 3 && !wasTouching) {
    checkFingerprint();
  }
}

// ===== SAFE MECHANICS =====
void triggerUnlock() {
  systemState = 1; wrongAttempts = 0; input = "";
  digitalWrite(RED_LED, LOW);
  digitalWrite(GREEN_LED, HIGH);
  beep();
  drawScreen();
}

void triggerLock() {
  systemState = 0; input = "";
  digitalWrite(RED_LED, HIGH);
  digitalWrite(GREEN_LED, LOW);
  beep();
  drawScreen();
}

// ===== UI MANAGER =====
void drawScreen() {
  tft.fillScreen(0);
  tft.setTextColor(0xFFFF);

  if (systemState == 1) {
    tft.setTextSize(3);
    tft.setCursor(70, 30);
    tft.setTextColor(0x07E0);
    tft.print(F("UNLOCKED!"));

    tft.setTextSize(2);
    tft.setTextColor(0xFFFF);
    tft.fillRect(40, 90, 240, 50, 0xF800);
    tft.setCursor(100, 105);
    tft.print(F("LOCK SAFE"));
    tft.fillRect(40, 160, 240, 50, 0x001F);
    tft.setCursor(90, 175);
    tft.print(F("CHANGE CODE"));
  } else {
    tft.setTextSize(2);
    tft.setCursor(10, 15);
    if (systemState == 0) tft.print(F("LOCKED"));
    else tft.print(F("NEW CODE"));

    tft.drawRect(210, 5, 100, 35, 0x07FF);
    tft.setCursor(215, 15);
    tft.setTextSize(1);
    if (currentMode == 0) tft.print(F("MODE: PIN"));
    else if (currentMode == 1) tft.print(F("MODE: PATTERN"));
    else if (currentMode == 2) tft.print(F("MODE: QWERTY"));
    else tft.print(F("MODE: PRINT"));
    tft.setTextSize(2);

    if (currentMode != 1 && currentMode != 3) tft.drawRect(10, 45, 300, 35, 0xFFFF);

    if (currentMode == 0) drawKeypad();
    else if (currentMode == 1) drawPatternGrid();
    else if (currentMode == 2) drawQwerty();
    else drawFingerprintScreen();
  }
}

// ===== DRAW KEYBOARDS =====
void drawKeypad() {
  int sx = 50, sy = 90; int num = 1;
  for (int r = 0; r < 3; r++) {
    for (int c = 0; c < 3; c++) {
      int x = sx + (c * 75); int y = sy + (r * 35);
      tft.drawRect(x, y, 65, 30, 0xFFFF); tft.setCursor(x + 25, y + 8); tft.print(num++);
    }
  }
  tft.fillRect(50, 195, 65, 30, 0xF800); tft.setCursor(65, 203); tft.print(F("DEL"));
  tft.drawRect(125, 195, 65, 30, 0xFFFF); tft.setCursor(150, 203); tft.print(F("0"));
  tft.fillRect(200, 195, 65, 30, 0x07E0); tft.setCursor(215, 203); tft.print(F("OK"));
}

void drawPatternGrid() {
  int sx = 100, sy = 80;
  for (int r = 0; r < 3; r++) {
    for (int c = 0; c < 3; c++) {
      tft.drawCircle(sx + (c * 60), sy + (r * 60), 15, 0xFFFF);
    }
  }
}

void drawQwerty() {
  tft.setTextSize(2);
  String r1 = "QWERTYUIOP"; String r2 = "ASDFGHJKL"; String r3 = "ZXCVBNM";
  for (int i = 0; i < 10; i++) { tft.drawRect(i * 32, 90, 30, 35, 0xFFFF); tft.setCursor(i * 32 + 8, 100); tft.print(r1[i]); }
  for (int i = 0; i < 9; i++) { tft.drawRect(16 + (i * 32), 130, 30, 35, 0xFFFF); tft.setCursor(16 + (i * 32) + 8, 140); tft.print(r2[i]); }
  for (int i = 0; i < 7; i++) { tft.drawRect(48 + (i * 32), 170, 30, 35, 0xFFFF); tft.setCursor(48 + (i * 32) + 8, 180); tft.print(r3[i]); }
  tft.fillRect(0, 210, 70, 30, 0xF800); tft.setCursor(15, 217); tft.print(F("DEL"));
  tft.drawRect(75, 210, 145, 30, 0xFFFF); tft.setCursor(130, 217); tft.print(F("SPACE"));
  tft.fillRect(225, 210, 95, 30, 0x07E0); tft.setCursor(255, 217); tft.print(F("OK"));
}

void drawFingerprintScreen() {
  tft.setTextSize(3);
  if (systemState == 0) {
    tft.setTextColor(0xFFFF);
    tft.setCursor(70, 120); tft.print(F("SCAN FINGER"));
  } else if (systemState == 2) {
    tft.fillRect(40, 100, 240, 60, 0x07E0);
    tft.setTextColor(0x0000);
    tft.setCursor(70, 120); tft.print(F("ADD FINGER"));
  }
}

// ===== SHOW TYPING =====
void showInput() {
  if (currentMode == 1 || currentMode == 3) return;
  tft.fillRect(12, 47, 296, 31, 0);
  tft.setCursor(15, 55); tft.setTextColor(0xFFFF); tft.print(input);
}

// ===== TOUCH LOGIC =====
void handleTouch(int x, int y) {
  if (systemState == 1) {
    if (y > 90 && y < 140 && x > 40 && x < 280) triggerLock();
    else if (y > 160 && y < 210 && x > 40 && x < 280) { beep(); systemState = 2; input = ""; drawScreen(); }
    return;
  }

  if (x > 210 && y > 5 && y < 40) {
    currentMode++; if (currentMode > 3) currentMode = 0;
    input = ""; beep(); drawScreen(); return;
  }

  if (currentMode == 3 && systemState == 2) {
    if (y > 100 && y < 160 && x > 40 && x < 280) enrollFingerprint();
    return;
  }

  String btn = getButton(x, y);
  if (btn != "") {
    if (btn == "DEL") {
      if (input.length() > 0) input = input.substring(0, input.length() - 1);
      beep(); showInput();
    } else if (btn == "OK") processSubmit();
    else {
      if (currentMode == 1) {
        if (!input.endsWith(btn)) {
          input += btn; beep();
          int num = btn.toInt();
          int r = (num - 1) / 3; int c = (num - 1) % 3;
          tft.fillCircle(100 + (c * 60), 80 + (r * 60), 10, 0x07E0);
        }
      } else if (currentMode == 0 || currentMode == 2) {
        if (input.length() < 12) { input += btn; beep(); showInput(); }
      }
    }
  }
}

// ===== PROCESS SUBMISSION =====
void processSubmit() {
  if (systemState == 0) {
    if (input == passwords[currentMode]) {
      triggerUnlock();
    } else {
      wrongAttempts++;
      tft.fillRect(10, 45, 300, 35, 0xF800); tft.setCursor(120, 55); tft.print(F("WRONG!"));
      beep(); delay(1000);
      if (wrongAttempts >= 3) alarm();
      input = ""; drawScreen();
    }
  } else if (systemState == 2) {
    passwords[currentMode] = input; savePassword(currentMode);
    systemState = 1; input = "";
    beep(); delay(100); beep(); drawScreen();
  }
}

// ===== FINGERPRINT LOGIC =====
void checkFingerprint() {
  uint8_t p = finger.getImage();
  if (p != FINGERPRINT_OK) return;

  p = finger.image2Tz();
  if (p != FINGERPRINT_OK) return;

  p = finger.fingerSearch();
  if (p == FINGERPRINT_OK) {
    triggerUnlock();
  } else {
    tft.fillRect(50, 110, 220, 40, 0xF800);
    tft.setCursor(60, 120);
    tft.setTextColor(0xFFFF);
    tft.print("ACCESS DENIED");
    beep();
    delay(1000);
    drawScreen();
  }
}

void enrollFingerprint() {
  // Find next available ID slot
  int id = 1;
  while (finger.loadModel(id) == FINGERPRINT_OK) {
    id++;
    if (id > 127) { 
      tft.fillScreen(0xF800);
      tft.setCursor(50, 100);
      tft.print("MEMORY FULL");
      delay(2000);
      return;
    }
  }

  tft.fillScreen(0);
  tft.setTextSize(3);
  tft.setTextColor(0xFFFF);
  tft.setCursor(50, 100);
  tft.print("PLACE FINGER");

  uint8_t p = -1;
  while (p != FINGERPRINT_OK) { p = finger.getImage(); }

  // Step 1: Convert first image
  p = finger.image2Tz(1);
  if (p != FINGERPRINT_OK) { showEnrollError("TZ1 ERR:", p); return; }
  beep();

  tft.fillScreen(0);
  tft.setCursor(30, 100);
  tft.print("REMOVE FINGER");
  delay(1500);
  while (finger.getImage() != FINGERPRINT_NOFINGER);

  tft.fillScreen(0);
  tft.setCursor(50, 100);
  tft.print("PLACE AGAIN");
  p = -1;
  while (p != FINGERPRINT_OK) { p = finger.getImage(); }

  // Step 2: Convert second image
  p = finger.image2Tz(2);
  if (p != FINGERPRINT_OK) { showEnrollError("TZ2 ERR:", p); return; }
  beep();

  // Step 3: Create the model
  p = finger.createModel();
  if (p != FINGERPRINT_OK) { showEnrollError("MATCH ERR:", p); return; }

  // Step 4: Save the model
  p = finger.storeModel(id);
  if (p == FINGERPRINT_OK) {
    tft.fillScreen(0x07E0);
    tft.setTextColor(0x0000);
    tft.setCursor(90, 100);
    tft.print("SAVED ID:");
    tft.setCursor(200, 100);
    tft.print(id);
    delay(1500);
  } else {
    showEnrollError("SAVE ERR:", p);
    return;
  }

  systemState = 1; 
  drawScreen();
}

// Updated Error function to show what went wrong
void showEnrollError(String step, int errorCode) {
  tft.fillScreen(0xF800); 
  tft.setTextColor(0xFFFF);
  tft.setTextSize(3);
  tft.setCursor(20, 80); 
  tft.print(step);
  tft.setCursor(80, 130);
  tft.print("CODE: ");
  tft.print(errorCode);
  delay(3000);
  systemState = 1; 
  drawScreen();
}

void showEnrollError() {
  tft.fillScreen(0xF800); tft.setTextColor(0xFFFF);
  tft.setCursor(90, 100); tft.print("ERROR!");
  delay(1500);
  systemState = 1;
  drawScreen();
}

// ===== HITBOX MATH =====
String getButton(int x, int y) {
  if (currentMode == 0) {
    int sx = 50, sy = 90;
    for (int r = 0; r < 3; r++) {
      for (int c = 0; c < 3; c++) {
        if (x > sx + (c * 75) && x < sx + (c * 75) + 65 && y > sy + (r * 35) && y < sy + (r * 35) + 30)
          return String(r * 3 + c + 1);
      }
    }
    if (y > 195 && y < 225) {
      if (x > 50 && x < 115) return "DEL";
      if (x > 125 && x < 190) return "0";
      if (x > 200 && x < 265) return "OK";
    }
  } else if (currentMode == 1) {
    int sx = 100, sy = 80;
    for (int r = 0; r < 3; r++) {
      for (int c = 0; c < 3; c++) {
        if (abs(x - (sx + c * 60)) < 25 && abs(y - (sy + r * 60)) < 25)
          return String(r * 3 + c + 1);
      }
    }
  } else if (currentMode == 2) {
    String r1 = "QWERTYUIOP"; String r2 = "ASDFGHJKL"; String r3 = "ZXCVBNM";
    if (y > 90 && y < 125) { int c = x / 32; if (c >= 0 && c < 10) return String(r1[c]); }
    if (y > 130 && y < 165) { int c = (x - 16) / 32; if (c >= 0 && c < 9) return String(r2[c]); }
    if (y > 170 && y < 205) { int c = (x - 48) / 32; if (c >= 0 && c < 7) return String(r3[c]); }
    if (y > 210 && y < 240) {
      if (x < 70) return "DEL";
      if (x > 75 && x < 220) return " ";
      if (x > 225) return "OK";
    }
  }
  return "";
}

// ===== ALARM =====
void alarm() {
  tft.fillScreen(0xF800); tft.setCursor(100, 110); tft.print(F("LOCKED!"));
  for (int i = 0; i < 6; i++) {
    digitalWrite(BUZZER, HIGH); delay(150);
    digitalWrite(BUZZER, LOW); delay(150);
  }
  wrongAttempts = 0;
}

// ===== PERMANENT MEMORY (EEPROM) =====
void loadAllPasswords() {
  for (int mode = 0; mode < 3; mode++) {
    int addressStart = mode * 20;
    if (EEPROM.read(addressStart) == 0x88) {
      int len = EEPROM.read(addressStart + 1);
      passwords[mode] = "";
      for (int i = 0; i < len; i++) passwords[mode] += (char)EEPROM.read(addressStart + 2 + i);
    } else {
      savePassword(mode);
    }
  }
}

void savePassword(int mode) {
  int addressStart = mode * 20;
  EEPROM.update(addressStart, 0x88);
  EEPROM.update(addressStart + 1, passwords[mode].length());
  for (int i = 0; i < passwords[mode].length(); i++) {
    EEPROM.update(addressStart + 2 + i, passwords[mode][i]);
  }
}

// ===== BUZZER =====
void beep() {
  digitalWrite(BUZZER, HIGH); delay(60); digitalWrite(BUZZER, LOW);
}
