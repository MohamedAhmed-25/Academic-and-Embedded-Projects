#include <iostream>
#include <fstream>
#include <string>
using namespace std;

const int MAX = 100;
const int SUBJECTS = 5;

// أسماء المواد
string subjectNames[SUBJECTS] = {
    "Math 1",
    "Discrete Math",
    "Programming 1",
    "Introduction to CS",
    "Electronic Physics"
};

// struct الطالب
struct Student {
    int id;
    string name;
    int level;
    int marks[SUBJECTS];
    int total;
    double average;
    bool passed;
};

// حساب المجموع والمتوسط وحالة النجاح
void calculate(Student& s) {
    s.total = 0;

    for (int i = 0; i < SUBJECTS; i++) {
        s.total += s.marks[i];
    }

    s.average = s.total / (double)SUBJECTS;

    if (s.average >= 50)
        s.passed = true;
    else
        s.passed = false;
}

// إضافة طالب
void addStudent(Student students[], int& count) {
    if (count >= MAX) {
        cout << "Cannot add more students!\n";
        return;
    }

    cout << "Enter student ID: ";
    cin >> students[count].id;

    cout << "Enter student name: ";
    cin.ignore();
    getline(cin, students[count].name);

    cout << "Enter student level: ";
    cin >> students[count].level;

    // إدخال درجات المواد بأسمائها
    for (int i = 0; i < SUBJECTS; i++) {
        do {
            cout << "Enter mark for " << subjectNames[i] << " (0 - 100): ";
            cin >> students[count].marks[i];
        } while (students[count].marks[i] < 0 || students[count].marks[i] > 100);
    }

    calculate(students[count]);
    count++;

    cout << "Student added successfully!\n\n";
}

// عرض كل الطلبة
void displayAll(Student students[], int count) {
    if (count == 0) {
        cout << "No students to display.\n\n";
        return;
    }

    for (int i = 0; i < count; i++) {
        cout << "\n==============================\n";
        cout << "ID   : " << students[i].id << endl;
        cout << "Name : " << students[i].name << endl;
        cout << "Level: " << students[i].level << endl;

        cout << "Marks:\n";
        for (int j = 0; j < SUBJECTS; j++) {
            cout << "- " << subjectNames[j]
                << ": " << students[i].marks[j] << "/100\n";
        }

        cout << "Total   : " << students[i].total << endl;
        cout << "Average : " << students[i].average << endl;
        cout << "Status  : "
            << (students[i].passed ? "Passed" : "Failed") << endl;
    }
    cout << endl;
}

// البحث بالـ ID
void searchStudent(Student students[], int count) {
    int id;
    cout << "Enter ID to search: ";
    cin >> id;

    for (int i = 0; i < count; i++) {
        if (students[i].id == id) {
            cout << "\nStudent Found!\n";
            cout << "Name: " << students[i].name << endl;
            cout << "Level: " << students[i].level << endl;

            cout << "Marks:\n";
            for (int j = 0; j < SUBJECTS; j++) {
                cout << "- " << subjectNames[j]
                    << ": " << students[i].marks[j] << "/100\n";
            }

            cout << "Average: " << students[i].average << endl;
            cout << "Status: "
                << (students[i].passed ? "Passed" : "Failed") << endl;
            return;
        }
    }

    cout << "Student not found.\n\n";
}

/// حفظ البيانات في ملف  
void saveToFile(Student students[], int count) {
    ofstream file("students.txt");

    for (int i = 0; i < count; i++) {
        file << "ID: " << students[i].id << endl;
        file << "Name: " << students[i].name << endl;
        file << "Level: " << students[i].level << endl;
        for (int j = 0; j < SUBJECTS; j++) {
            file << subjectNames[j] << ": " << students[i].marks[j] << endl;
        }
        file << "Total: " << students[i].total << endl;
        file << "Average: " << students[i].average << endl;
        file << "Status: " << (students[i].passed ? "Passed" : "Failed") << endl;
        file << "==============================\n";
    }

    file.close();
    cout << "Data saved to file.\n\n";
}

// BONUS: تحميل البيانات من ملف
void loadFromFile(Student students[], int& count) {
    ifstream file("students.txt");
    count = 0;

    while (file >> students[count].id >> students[count].name) {
        for (int j = 0; j < SUBJECTS; j++) {
            file >> students[count].marks[j];
        }
        calculate(students[count]);
        count++;
    }

    file.close();
    cout << "Data loaded from file.\n\n";
}

// main
int main() {
    Student students[MAX];
    int count = 0;
    int choice;

    do {
        cout << "===== Student Grade Management System =====\n";
        cout << "1. Add Student\n";
        cout << "2. Display All Students\n";
        cout << "3. Search by ID\n";
        cout << "4. Save to File (Bonus)\n";
        cout << "5. Load from File (Bonus)\n";
        cout << "6. Exit\n";
        cout << "Choose: ";
        cin >> choice;

        switch (choice) {
        case 1: addStudent(students, count); break;
        case 2: displayAll(students, count); break;
        case 3: searchStudent(students, count); break;
        case 4: saveToFile(students, count); break;
        case 5: loadFromFile(students, count); break;
        case 6: cout << "Program Ended.\n"; break;
        default: cout << "Invalid choice!\n";
        }

    } while (choice != 6);

    return 0;
}
